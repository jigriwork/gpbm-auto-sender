{
  "name": "gpbm-auto-sender",
  "version": "0.1.0",
  "private": true,
  "description": "SaaS-ready dashboard and local agent for automatic PDF bill delivery over WhatsApp.",
  "scripts": {
    "dev": "npm run dev -w @gpbm/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "setup:local-env": "tsx scripts/setup-local-env.ts",
    "setup:agent-envs": "tsx scripts/write-local-agent-envs.ts",
    "verify:supabase": "tsx scripts/verify-supabase.ts",
    "agent:create": "tsx scripts/create-agent-device.ts",
    "smoke:agent": "tsx scripts/smoke-agent-api.ts"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "devDependencies": {
    "supabase": "^2.108.0"
  }
}
